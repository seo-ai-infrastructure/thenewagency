# ────────────────────────────────────────────────────────────────────────────
# Secrets for agency-local-serp-os.  Copy to secrets.env, fill in, then either:
#   source secrets.env           # before running commands by hand
# or export these inside your launchd/cron wrapper (a sourced shell does NOT
# reach scheduled jobs — see docs/SETUP-REDIS.md).  NEVER commit secrets.env.
# Only fill in the keys for the subsystems you actually run.
# ────────────────────────────────────────────────────────────────────────────

# --- SERP estate tracker (DataForSEO) — Basic auth (login:password) ---
export DATAFORSEO_LOGIN="your-dataforseo-login"
export DATAFORSEO_PASSWORD="your-dataforseo-password"

# --- Zernio publisher (GBP + 14 social platforms) — Bearer ---
export ZERNIO_API_KEY="your-zernio-api-key"

# --- content-writer LLM gate (drafting posts / review replies) ---
export ANTHROPIC_API_KEY="your-anthropic-api-key"
export CLAUDE_MODEL="claude-sonnet-4-5"        # not secret; set to your real model id

# --- DuoPlus RPA (phone control) — header DuoPlus-API-Key ---
# NOTE: the live DuoPlus path still raises NotImplementedError until you wire it,
# so this is not read yet — fill it when you implement the live device calls.
export DUOPLUS_API_KEY="your-duoplus-api-key"

# --- Redis coordination (MULTI-MACHINE ONLY; single machine uses file locks) ---
# These live in redis.env (already templated). Only needed if REDIS_HOST is set.
# export REDIS_HOST="redis-13875.c245.us-east-1-3.ec2.cloud.redislabs.com"
# export REDIS_PORT="13875"
# export REDIS_PASSWORD="your-redis-password"
# export REDIS_CA="/abs/path/redis_ca.pem"     # ONLY if you enable TLS (yours is off)

# --- CloakBrowser proxies (BYO; one sticky proxy per agent profile) ---
# Map profiles.yaml proxy_ref -> creds here (naming is your choice; the live client reads them).
# export PROXY_01="http://user:pass@host:port"
# export PROXY_02="http://user:pass@host:port"

# --- Notifications (enable either or both; unset = silent) ---
# Telegram: message @BotFather -> /newbot -> copy the token; get your chat id from @userinfobot.
# export TELEGRAM_BOT_TOKEN="123456:ABC..."
# export TELEGRAM_CHAT_ID="987654321"
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# export DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/.../..."

# --- Google media generation (video-producer: Nano Banana image + Veo video) ---
# Live calls SPEND money (image ~$0.05-0.24, video ~$0.15-0.40/sec). Get a key at aistudio.google.com.
# export GOOGLE_API_KEY="..."
# export NANOBANANA_MODEL="gemini-3-flash-image"        # or gemini-3-pro-image-preview
# export VEO_MODEL="veo-3.1-fast-generate-preview"      # or veo-3.1-generate-preview / lite

# --- Asset hosting (bridge_asset_to_post): you sync assets to a CDN/bucket, give the base URL ---
# Sync clients/<id>/rpa/assets/<draft_id>/ to {ASSET_BASE_URL}/<id>/<draft_id>/
# export ASSET_BASE_URL="https://cdn.example.com/assets"

# ── Content & publishing workflows ────────────────────────────────────────────
# Only WordPress, Cloudflare, Castopod, ElevenLabs use API keys.
# Social/video (Facebook, Reddit, TikTok, Quora, YouTube) need NO keys — they post
# like a human via the per-client CloakBrowser profile "<client>-cb-agent".

# --- WordPress (self-hosted, REST + Application Password; ONE env var PER CLIENT) ---
# Create in WP: Users -> Profile -> Application Passwords. Site url + username live in
# clients/<id>/config/wordpress.yaml; only the password is a secret here.
# export WP_APP_PASSWORD_EXAMPLE_HVAC="xxxx xxxx xxxx xxxx xxxx xxxx"

# --- Cloudflare edge (deploy HTML+Schema workers) ---
# export CLOUDFLARE_API_TOKEN="..."
# export CF_ACCOUNT_ID="..."

# --- Castopod (self-hosted podcast host; episode + RSS -> Spotify/Apple/YouTube) ---
# export CASTOPOD_API_BASE="https://podcast.your-instance.com"
# export CASTOPOD_API_TOKEN="..."

# --- ElevenLabs (voice / podcast TTS) ---
# export ELEVENLABS_API_KEY="..."
# export ELEVENLABS_VOICE_ID="..."          # pick a voice in the ElevenLabs dashboard
